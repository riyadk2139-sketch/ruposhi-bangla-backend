# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET
JWT_EXPIRES_IN=7d

# ─── Database (PostgreSQL) ────────────────────────────────────────────────────
# Supabase:  postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres
# Railway:   from the Railway dashboard → Variables → DATABASE_URL
# Render:    from the Render dashboard → PostgreSQL → Connection String
DATABASE_URL=postgresql://user:password@host:5432/ruposhi_bangla
DB_SSL=true

# Set to true on first deploy to run pending migrations automatically
RUN_MIGRATIONS=true

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (your Expo EAS build URL or web domain)
ALLOWED_ORIGINS=https://yourapp.com
